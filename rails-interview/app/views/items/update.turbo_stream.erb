<% todo_list.reload %>
<%= render "shared/flash_toast_streams", formats: [:html] %>

<%= turbo_stream.replace dom_id(item) do %>
  <%= render 'items/item', item: %>
<% end %>

<%= turbo_stream.replace dom_id(todo_list, :summary) do %>
  <%= turbo_frame_tag dom_id(todo_list, :summary) do %>
    <%= render 'todo_lists/summary', todo_list: %>
  <% end %>
<% end %>

