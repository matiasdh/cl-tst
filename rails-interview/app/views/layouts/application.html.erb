<!DOCTYPE html>
<html>
  <head>
    <title>RailsInterview</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900">
    <div id="toast-container" class="fixed top-4 right-4 z-50 flex flex-col gap-2 pointer-events-none" aria-live="polite">
      <%= render "shared/flash" %>
    </div>

    <header class="border-b border-slate-200 bg-white">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
        <%= link_to 'Todos', root_path, class: "text-lg font-semibold tracking-tight text-slate-900" %>
        <%= link_to 'Add list', new_todo_list_path, class: "inline-flex items-center rounded-lg bg-sky-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-sky-700" %>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-6">
      <%= yield %>
    </main>
  </body>
</html>
