<%
  items_to_show = local_assigns[:items]
  pagy_obj = local_assigns[:pagy]
  items_to_show ||= todo_list.items.order(id: :desc)
%>
<%= turbo_frame_tag dom_id(todo_list, :items), data: { action: "turbo:frame-load->items-selection#resetSelection" } do %>
  <div class="flex flex-col space-y-4" data-items-selection-target="list">
    <% items_to_show.each do |item| %>
      <%= render "items/item", item: %>
    <% end %>
  </div>
  <% if pagy_obj %>
    <div class="mt-4 flex justify-center">
      <%== pagy_obj.series_nav(id: "todo-items-pagy", aria_label: "Items pages") %>
    </div>
  <% end %>
<% end %>
